DB_PORT=5434
DB_NAME=bi_db

# Schema names
DB_SCHEMA_STAGING=staging
DB_SCHEMA_DWH=dw

# Table names
RAW_TABLE=vnretail_data_xlsx
MARKETING_DIM_DATE_TABLE=dim_date
