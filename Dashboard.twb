      <aliases enabled='yes' />
      <column caption='Biên LN %' datatype='real' name='[Calculation_2117740678856704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([revenue])' />
      </column>
      <column caption='% Nguyen lieu' datatype='real' name='[Calculation_2117740692377601]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([raw_material_cost]) / SUM([revenue])' />
      </column>
      <column caption='% Nhan cong' datatype='real' name='[Calculation_2117740692443138]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([labor_cost]) / SUM([revenue])' />
      </column>
      <column caption='% Logistics' datatype='real' name='[Calculation_2117740692500483]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([logistics_cost]) / SUM([revenue])' />
      </column>
      <column caption='% Marketing CF' datatype='real' name='[Calculation_2117740692676613]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([marketing_cost]) / SUM([revenue])' />
      </column>
      <column caption='DT_Ty' datatype='real' name='[Calculation_3141317629591553]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(SUM([revenue])/1000000, 1)' />
      </column>
      <column caption='Profit_B' datatype='real' name='[Calculation_3141317631057922]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(SUM([profit])/1000000, 1)' />
      </column>
      <column caption='Margin_Pct' datatype='real' name='[Calculation_3141317631635459]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])/SUM([revenue])' />
      </column>
      <column caption='Top Category' datatype='integer' name='[Calculation_3141317637169156]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([category_name])' />
      </column>
      <column caption='Total Products' datatype='integer' name='[Calculation_3403207564054528]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([product_name])' />
      </column>
      <column caption=' Total Branches' datatype='integer' name='[Calculation_3403207567998977]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([branch_name])' />
      </column>
      <column caption='Total Regions' datatype='integer' name='[Calculation_3403207568596995]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([region_name])' />
      </column>
      <column caption='Avg Revenue/Branch' datatype='real' name='[Calculation_3403207568973828]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue]) / COUNTD([branch_name]) / 1000000' />
      </column>
      <column caption='Best channel' datatype='integer' name='[Calculation_3403207573118981]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([channel_name])' />
      </column>
      <column caption='YoY_Growth' datatype='real' name='[Calculation_3403207573659654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='POWER(&#10;  SUM(IF [year] = 2025 THEN [revenue] END) /&#10;  SUM(IF [year] = 2021 THEN [revenue] END),&#10;  1.0/4&#10;) - 1' />
      </column>
      <column caption='DT_Ty_Seg' datatype='real' name='[Calculation_3483059614744576]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(SUM([revenue])/1000000, 1)' />
      </column>
      <column caption='Num_Segments' datatype='integer' name='[Calculation_3483059616129026]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([segment_name])' />
      </column>
      <column caption='Avg_ROI' datatype='real' name='[Calculation_3483059617587203]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([roi_marketing])' />
      </column>
      <column caption='Calculation1' datatype='boolean' name='[Calculation_4216777801564160]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[revenue] &gt;= [target]' />
      </column>
      <column caption='CalculationDat' datatype='boolean' name='[Calculation_4216777801662465]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[revenue] &gt;= [target]' />
      </column>
      <column caption='Calculation2' datatype='string' name='[Calculation_4216777804382211]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([year]) = 2021 THEN &quot;Base&quot;&#10;ELSEIF SUM([revenue]) &gt; LOOKUP(SUM([revenue]),-1) THEN &quot;Tăng&quot;&#10;ELSE &quot;Giảm&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Branch Revenue %' datatype='real' name='[Calculation_4216777809723398]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue]) / TOTAL(SUM([revenue]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='LastYear' datatype='real' name='[Calculation_4216777830420487]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([revenue]) - LOOKUP(SUM([revenue]), -1)) / ABS(LOOKUP(SUM([revenue]), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
